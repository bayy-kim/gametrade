generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  email        String        @unique
  password     String
  role         String        @default("user")
  rating       Float         @default(0)
  totalReviews Int           @default(0)
  createdAt    DateTime      @default(now())
  accounts     Account[]
  transactions Transaction[] @relation("TransactionBuyer")
  soldAccounts Transaction[] @relation("TransactionSeller")
}

model Account {
  id             Int           @id @default(autoincrement())
  sellerId       Int
  game           String
  gameId         String
  serverId       String?
  accountLevel   Int?
  accountRank    String?
  heroesSkins    String?
  description    String?
  price          Float?
  tradeOnly      Boolean       @default(false)
  screenshots    String
  googleVerified Boolean       @default(false)
  gameIdActive   Boolean       @default(false)
  status         String        @default("pending")
  verifiedByAi   Boolean       @default(false)
  aiVerifiedAt   DateTime?
  rejectionReason String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  seller         User          @relation(fields: [sellerId], references: [id])
  transactions   Transaction[]
}

model Transaction {
  id              Int      @id @default(autoincrement())
  transactionCode String
  type            String
  buyerId         Int
  sellerId        Int
  accountId       Int
  amount          Float?
  adminFee        Float    @default(5000)
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  buyer           User     @relation("TransactionBuyer", fields: [buyerId], references: [id])
  seller          User     @relation("TransactionSeller", fields: [sellerId], references: [id])
  account         Account  @relation(fields: [accountId], references: [id])
}